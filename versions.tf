terraform {
  required_version = ">= 1.5"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.60"
    }
  }
}

provider "aws" {
  region = var.region

  default_tags {
    tags = {
      Project = "SOA03-6DAY"
      Lab     = "EBS-Volumes-Performance-DataProtection"
    }
  }
}
